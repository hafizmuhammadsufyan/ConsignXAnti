# Email Configuration
# For Gmail: Generate app password from https://myaccount.google.com/apppasswords
# Make sure 2-Factor Authentication is enabled on your Gmail account
MAIL_FROM_ADDRESS=noreply@consignx.com
MAIL_FROM_NAME=ConsignX Team

# SMTP Server Config (Using Mailtrap for Development OR Gmail)
# === OPTION 1: Using Gmail (Recommended for Production) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_ENCRYPTION=tls
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_DEBUG=0

# === OPTION 2: Using Mailtrap (Recommended for Development) - CURRENTLY ACTIVE ===
# Get free account at https://mailtrap.io/ and copy credentials from Integrations > PHPMailer
SMTP_HOST=live.smtp.mailtrap.io
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=api
SMTP_PASSWORD=YOUR_MAILTRAP_TOKEN_HERE
SMTP_DEBUG=0
SMTP_DEBUG=0

# Local Mail Testing (For XAMPP - No actual email sends, just logs)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_ENCRYPTION=none
